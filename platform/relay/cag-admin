#!/bin/sh
set -eu

if [ "$(id -u)" -ne 0 ]; then
  echo "cag-admin must run as root" >&2
  exit 1
fi

case "${1:-}" in
  invite)
    shift
    exec /opt/cag/cag-state create-invite "$@"
    ;;
  status)
    [ "$#" -eq 2 ] || exit 2
    exec /opt/cag/cag-state device-status "$2"
    ;;
  *)
    echo "usage: cag-admin invite [--ttl SECONDS] | status DEVICE_ID" >&2
    exit 2
    ;;
esac
