# Managed by Ansible. Authentication lockdown is intentionally separate.
PermitEmptyPasswords no
LoginGraceTime 20
MaxAuthTries 3
MaxStartups 30:30:100
PerSourceMaxStartups 10
PerSourcePenalties crash:90s authfail:5s invaliduser:5s noauth:1s grace-exceeded:10s refuseconnection:10s max:10m min:15s overflow:permissive
X11Forwarding no
AllowAgentForwarding no
PermitUserEnvironment no
ClientAliveInterval 300
ClientAliveCountMax 2
